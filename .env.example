# UniFi controller credentials (optional -- can also log in via the UI)
UNIFI_URL=https://192.168.1.1
UNIFI_SITE=default
UNIFI_USER=admin
UNIFI_PASS=changeme
UNIFI_VERIFY_SSL=false

# Application auth (optional -- when set, gates all API access behind a passphrase)
# APP_PASSWORD=your-secret-passphrase
# APP_SESSION_TTL=86400

# AI provider (optional -- can also configure via the Settings UI)
# AI_BASE_URL=https://api.openai.com/v1
# AI_API_KEY=sk-your-api-key
# AI_API_KEY_FILE=/run/secrets/ai_api_key
# AI_MODEL=gpt-4o
# AI_PROVIDER_TYPE=openai

# Application settings
# LOG_LEVEL=INFO
# APP_ACCESS_URL=http://localhost:8080
# PORT=8080
