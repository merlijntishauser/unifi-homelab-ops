    "destination_zone_id": "zone-external",
    "index": 100
  },
  {
    "_id": "rule-2",
    "name": "Allow Guest Web Access",
    "description": "Allow Guest zone to access web on WAN",
    "enabled": true,
    "action": "ALLOW",
    "source_zone_id": "zone-guest",
    "destination_zone_id": "zone-external",
    "protocol": "tcp",
    "port_ranges": ["80", "443"],
    "index": 200
  },
  {
    "_id": "rule-3",
    "name": "Allow Guest DNS",
    "description": "Allow Guest zone to resolve DNS",
    "enabled": true,
    "action": "ALLOW",
    "source_zone_id": "zone-guest",
    "destination_zone_id": "zone-external",
    "protocol": "udp",
    "port_ranges": ["53"],
    "destination": {
      "port_group_id": "group-dns-ports",
      "address_group_id": "group-dns-servers"
    },
    "index": 210
  },
  {
    "_id": "rule-4",
    "name": "Block Guest Other Traffic",
